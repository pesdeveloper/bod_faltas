flowchart TD

classDef inicio fill:#1f4b99,color:#ffffff
classDef proceso fill:#e8f0fe,color:#111111
classDef decision fill:#fff4cc,color:#111111
classDef evento fill:#e7f7e7,color:#111111
classDef error fill:#fde7e9,color:#111111
classDef destino fill:#0f9d58,color:#ffffff

A["D4<br/>ANÁLISIS<br/>ACTA"]:::inicio

A --> B["Iniciar<br/>análisis"]:::proceso
B --> E1["Evento<br/>ANALISIS_INICIADO"]:::evento

E1 --> C{"¿Acta válida?"}:::decision

C -- NO --> E2["Evento<br/>ACTA_INVALIDA"]:::error
E2 --> D8["→ D8B"]:::destino

C -- SI --> D["Evaluar<br/>descargo"]:::proceso
D --> E3["Evento<br/>DESCARGO_REGISTRADO"]:::evento

E3 --> E["Evaluar<br/>pago (P2)"]:::proceso
E --> E4["Evento<br/>PAGO_REGISTRADO"]:::evento

E4 --> F["Evaluar<br/>evidencia"]:::proceso
F --> E5["Evento<br/>EVIDENCIA_EVALUADA"]:::evento

E5 --> G{"¿Resultado?"}:::decision

G -- RESOLVER --> H["Evento<br/>ACTA_LISTA_PARA_RESOLUCION"]:::evento
H --> D5["→ D5"]:::destino

G -- ARCHIVAR --> I["Evento<br/>ACTA_ARCHIVADA"]:::evento
I --> D8

G -- PARALIZAR --> J["Evento<br/>ACTA_PARALIZADA"]:::evento
J --> K["Situación<br/>administrativa"]:::proceso

G -- CONTINUAR --> B