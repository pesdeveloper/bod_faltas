flowchart TD

classDef inicio fill:#1f4b99,color:#ffffff,stroke:none
classDef proceso fill:#e8f0fe,color:#111111,stroke:none
classDef decision fill:#fff4cc,color:#111111,stroke:none
classDef evento fill:#e7f7e7,color:#111111,stroke:none
classDef documento fill:#f3e8ff,color:#111111,stroke:none
classDef retorno fill:#0f9d58,color:#ffffff,stroke:none
classDef alerta fill:#fde7e9,color:#111111,stroke:none

A["D6<br/>NOTIFICACIÓN DEL ACTO RESOLUTIVO"]:::inicio

A --> B{"¿Acto resolutivo<br/>notificable?"}:::decision

B -- "NO" --> B1["Registrar impedimento"]:::alerta
B1 --> E0["Evento<br/>ACTO_NOTIFICABLE_INVALIDO"]:::evento
E0 --> R0["→ Revisión administrativa"]:::retorno

B -- "SI" --> C{"¿Requiere documento<br/>accesorio?"}:::decision

C -- "SI" --> D["Invocar P1<br/>OrigenProceso = D6"]:::documento
D --> D1{"¿Resultado de P1?"}:::decision

D1 -- "DocumentoFormalListo" --> D2["Usar documento accesorio"]:::documento
D1 -- "SinDocumento" --> E["Continuar sin documento<br/>accesorio"]:::proceso
D1 -- "DocumentoPendienteFirma" --> E1["Evento<br/>DOCUMENTO_NOTIFICACION_ACTO_PENDIENTE"]:::evento
E1 --> R1["→ Permanecer en D6"]:::retorno
D1 -- "ErrorAutorizacion / ErrorFirma" --> E2["Evento<br/>ERROR_DOCUMENTO_NOTIFICACION_ACTO"]:::evento
E2 --> R2["→ Permanecer en D6"]:::retorno

D2 --> F["Invocar P3<br/>OrigenProceso = D6"]:::proceso
E --> F

C -- "NO" --> F

F --> G{"¿Resultado de P3?"}:::decision

G -- "NotificacionPerfeccionada" --> E3["Evento<br/>ACTO_NOTIFICADO"]:::evento
E3 --> H["Evaluar efecto del acto"]:::proceso

G -- "NotificacionPendiente" --> E4["Evento<br/>NOTIFICACION_ACTO_PENDIENTE"]:::evento
E4 --> R3["→ Permanecer en D6"]:::retorno

G -- "MedioNoDisponible" --> E5["Evento<br/>MEDIO_NOTIFICACION_ACTO_INDISPONIBLE"]:::evento
E5 --> I["Decidir continuidad"]:::proceso

G -- "NotificacionNoConfirmada" --> E6["Evento<br/>NOTIFICACION_ACTO_NO_CONFIRMADA"]:::evento
E6 --> I

G -- "ReintentoPreparado" --> E7["Evento<br/>REINTENTO_NOTIFICACION_ACTO_PREPARADO"]:::evento
E7 --> R4["→ Permanecer en D6"]:::retorno

G -- "ImposibilidadDeNotificacion" --> E8["Evento<br/>IMPOSIBILIDAD_NOTIFICACION_ACTO"]:::evento
E8 --> I

G -- "SinNotificacion" --> I

H --> J{"¿Efecto del acto?"}:::decision

J -- "PASA_A_D7" --> E9["Evento<br/>ACTA_PASA_A_D7"]:::evento
E9 --> R5["→ D7"]:::retorno

J -- "PARALIZA" --> E10["Evento<br/>ACTA_PARALIZADA"]:::evento
E10 --> R6["→ Situación administrativa interna"]:::retorno

J -- "ARCHIVA" --> E11["Evento<br/>ACTA_ARCHIVADA"]:::evento
E11 --> R7["→ D8B"]:::retorno

I --> K{"¿Qué hacer?"}:::decision

K -- "REINTENTAR" --> E12["Evento<br/>REINTENTO_NOTIFICACION_ACTO_DISPUESTO"]:::evento
E12 --> R8["→ Permanecer en D6"]:::retorno

K -- "CAMBIAR_MEDIO" --> E13["Evento<br/>CAMBIO_MEDIO_NOTIFICACION_ACTO"]:::evento
E13 --> R9["→ Permanecer en D6"]:::retorno

K -- "PERMANECER_EN_D6" --> E14["Evento<br/>ACTA_PERMANECE_EN_D6"]:::evento
E14 --> R10["→ D6"]:::retorno

K -- "ARCHIVAR_EN_D8B" --> E15["Evento<br/>ARCHIVO_POR_IMPOSIBILIDAD_NOTIFICACION_ACTO"]:::evento
E15 --> R11["→ D8B"]:::retorno

class A inicio
class B,C,D1,G,J,K decision
class E,F,H,I proceso
class E0,E1,E2,E3,E4,E5,E6,E7,E8,E9,E10,E11,E12,E13,E14,E15 evento
class D,D2 documento
class R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11 retorno
class B1 alerta