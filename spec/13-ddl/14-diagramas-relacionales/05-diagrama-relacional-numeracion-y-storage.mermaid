erDiagram
    PoliticaNumeracion ||--o{ Talonario : define
    Talonario ||--o{ TalonarioDependencia : asigna_a
    Talonario ||--o{ TalonarioInsp : asigna_a
    Talonario ||--o{ TalonarioMovimiento : mueve
    Talonario ||--o{ Documento : numera
    StorageBackend ||--o{ StoragePolitica : resuelve
    StorageBackend ||--o{ StorageObjeto : almacena

    PoliticaNumeracion {
        INT IdPolNum PK
        VARCHAR48 NomPolNum
        SMALLINT TipoTalonario
        SMALLINT SiUsaPrefijo
        VARCHAR10 Prefijo
        SMALLINT SiUsaAnio
        SMALLINT SiUsaSerie
        SMALLINT LongNro
        CHAR1 SepPrefAnio
        CHAR1 SepAnioSerie
        CHAR1 SepSerieNro
        INT ProxNro
        SMALLINT SiActiva
        DATETIME FhVigDesde
        DATETIME FhVigHasta
    }

    Talonario {
        INT IdTalonario PK
        INT IdPolNum FK
        VARCHAR4 CodTalonario
        SMALLINT TipoTalonario
        SMALLINT AmbitoTalonario
        VARCHAR10 Serie
        INT NroDesde
        INT NroHasta
        INT UltNroUsado
        SMALLINT SiBloqueado
        CHAR36 CodDesbloqueo
        SMALLINT SiActiva
        VARCHAR255 ObsTalonario
        DATETIME FhAlta
        CHAR36 IdUserAlta
    }

    TalonarioDependencia {
        INT IdTalonario FK
        INT IdDep
        SMALLINT VerDep
        DATETIME FhDesde
        DATETIME FhHasta
        SMALLINT SiActiva
    }

    TalonarioInsp {
        INT IdTalonario FK
        INT IdInsp
        SMALLINT VerInsp
        DATETIME FhDesde
        DATETIME FhHasta
        SMALLINT SiActiva
    }

    TalonarioMovimiento {
        INT8 Id PK
        INT IdTalonario FK
        INT NroUsado
        SMALLINT EstadoNro
        VARCHAR80 MotivoMov
        INT8 IdActa
        INT IdDep
        SMALLINT VerDep
        INT IdInsp
        SMALLINT VerInsp
        DATETIME FhMov
        CHAR36 IdUserMov
    }

    StorageBackend {
        INT IdStorageBackend PK
        VARCHAR64 NomStorageBackend
        SMALLINT TipoBackend
        VARCHAR255 BasePath
        VARCHAR120 BucketContenedor
        VARCHAR120 PrefijoRuta
        SMALLINT SiDefault
        SMALLINT SiActivo
        VARCHAR255 ObsBackend
        DATETIME FhAlta
        CHAR36 IdUserAlta
    }

    StoragePolitica {
        INT IdStoragePolitica PK
        VARCHAR20 Sistema
        VARCHAR30 Familia
        VARCHAR30 TipoObjeto
        INT IdStorageBackend FK
        SMALLINT Prioridad
        SMALLINT SiActiva
        DATETIME FhVigDesde
        DATETIME FhVigHasta
        VARCHAR255 ObsPolitica
    }

    StorageObjeto {
        VARCHAR64 StorageKey PK
        INT IdStorageBackend FK
        VARCHAR20 Sistema
        VARCHAR30 Familia
        VARCHAR30 TipoObjeto
        SMALLINT Anio
        SMALLINT Mes
        SMALLINT Bucket
        VARCHAR80 RefNegocio
        VARCHAR120 NomArchivo
        VARCHAR10 ExtArchivo
        VARCHAR80 MimeType
        INT8 TamBytes
        VARCHAR128 HashArchivo
        VARCHAR255 RutaRelativa
        SMALLINT EstadoStorage
        DATETIME FhAlta
        CHAR36 IdUserAlta
    }