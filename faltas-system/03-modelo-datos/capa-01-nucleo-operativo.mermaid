flowchart TD

    A["ACTA<br/>Entidad central del sistema<br/>Snapshot operativo actual"]:::core

    AE["ACTA_EVENTO<br/>Historial append-only<br/>Trazabilidad completa"]:::event
    AD["ACTA_DOMICILIO<br/>Domicilio inicial y domicilios asociados<br/>Principal / operativo / reutilizable"]:::entity
    AV["ACTA_EVIDENCIA<br/>Evidencias del acta<br/>No documentales"]:::entity
    AO["ACTA_OBSERVACION<br/>Observaciones operativas<br/>Separadas del evento"]:::entity

    AT["ACTA_TRANSITO<br/>Extensión 1:1<br/>Dominio tránsito"]:::subtype
    AC["ACTA_CONTRAVENCION<br/>Extensión 1:1<br/>Dominio contravencional"]:::subtype
    ACM["ACTA_CONTRAVENCION_MEDIDA<br/>Medidas asociadas<br/>Sólo contravención"]:::subtype

    I["INSPECTORES<br/>Catálogo vivo"]:::catalog
    IS["INSPECTORES_SNAPSHOT<br/>Versión histórica<br/>referenciada por IdInspector + VersionInspector"]:::catalog

    C["CMTEXACTA<br/>Relación futura prevista"]:::future

    A -->|"1:N"| AE
    A -->|"1:N"| AD
    A -->|"1:N"| AV
    A -->|"1:N"| AO

    A -->|"0:1"| AT
    A -->|"0:1"| AC
    AC -->|"1:N"| ACM

    A -->|"FK IdInspector"| I
    A -->|"IdInspector + VersionInspector"| IS

    A -.->|"IdActaDomicilioPrincipal"| AD
    A -.->|"proyección futura"| C

    N1["Regla<br/>Toda acta nace con al menos un ActaDomicilio"]:::rule
    N2["Regla<br/>El domicilio inicial debe marcarse<br/>EsDomicilioActa = 1"]:::rule
    N3["Regla<br/>Acta guarda IdActaDomicilioPrincipal"]:::rule
    N4["Regla<br/>Latitud / Longitud viven en Acta<br/>no en Evidencia"]:::rule
    N5["Regla<br/>Evidencias pertenecen al acta<br/>no al documento formal"]:::rule
    N6["Regla<br/>No se reabre<br/>se reingresa por evento"]:::rule

    AD -.-> N1
    AD -.-> N2
    A -.-> N3
    AV -.-> N4
    AV -.-> N5
    AE -.-> N6

    classDef core fill:#1565c0,color:#ffffff,stroke:#0d47a1,stroke-width:2px;
    classDef event fill:#00838f,color:#ffffff,stroke:#006064,stroke-width:2px;
    classDef entity fill:#1e88e5,color:#ffffff,stroke:#1565c0,stroke-width:1.5px;
    classDef subtype fill:#3949ab,color:#ffffff,stroke:#283593,stroke-width:1.5px;
    classDef catalog fill:#6d4c41,color:#ffffff,stroke:#4e342e,stroke-width:1.5px;
    classDef future fill:#546e7a,color:#ffffff,stroke:#37474f,stroke-width:1.5px,stroke-dasharray: 5 5;
    classDef rule fill:#f9a825,color:#000000,stroke:#f57f17,stroke-width:1.5px;