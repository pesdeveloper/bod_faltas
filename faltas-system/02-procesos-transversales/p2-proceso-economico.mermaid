flowchart TD

%% =========================
%% ESTILOS
%% =========================
classDef inicio fill:#1f4b99,color:#ffffff,stroke:none
classDef proceso fill:#e8f0fe,color:#111111,stroke:none
classDef decision fill:#fff4cc,color:#111111,stroke:none
classDef evento fill:#e7f7e7,color:#111111,stroke:none
classDef documento fill:#f3e8ff,color:#111111,stroke:none
classDef retorno fill:#0f9d58,color:#ffffff,stroke:none
classDef alerta fill:#fde7e9,color:#111111,stroke:none
classDef fin fill:#455a64,color:#ffffff,stroke:none

%% =========================
%% INICIO
%% =========================
A["P2<br/>PROCESO ECONÓMICO<br/>Invocado desde cualquier bloque"]:::inicio

%% =========================
%% LIQUIDACIÓN
%% =========================
A --> B{"¿Existe liquidación<br/>válida?"}:::decision

B -- "NO" --> C["Generar / calcular<br/>liquidación"]:::proceso
C --> E1["LIQUIDACION_GENERADA"]:::evento
E1 --> D

B -- "SI" --> D["Usar liquidación vigente"]:::proceso

%% =========================
%% TIPO DE GESTIÓN
%% =========================
D --> E{"¿Tipo de gestión?"}:::decision

E -- "INTENCION" --> F["Registrar intención de pago"]:::proceso
F --> E2["INTENCION_PAGO_REGISTRADA"]:::evento
E2 --> R1["→ Retornar al origen"]:::retorno

E -- "PAGO INFORMADO" --> G["Registrar pago<br/>pendiente"]:::proceso
G --> E3["PAGO_PRECONFIRMADO"]:::evento

%% =========================
%% VALIDACIÓN DE PAGO
%% =========================
E3 --> H{"¿Pago confirmado?"}:::decision

H -- "NO" --> H1{"¿Pago inválido?"}:::decision

H1 -- "SI" --> H2["Marcar pago inválido"]:::proceso
H2 --> E4["PAGO_INVALIDO"]:::evento
E4 --> R2["→ Retornar al origen"]:::retorno

H1 -- "NO" --> E5["PAGO_PENDIENTE"]:::evento
E5 --> R3["→ Permanecer / esperar"]:::retorno

%% =========================
%% PAGO CONFIRMADO
%% =========================
H -- "SI" --> I["Registrar pago confirmado<br/>impactar cuenta económica<br/>ID_SUJ_FALTAS"]:::proceso
I --> E6["PAGO_CONFIRMADO"]:::evento

%% =========================
%% RECIBO
%% =========================
E6 --> J["Emitir recibo<br/>pagador real"]:::documento
J --> E7["RECIBO_EMITIDO"]:::evento

%% =========================
%% LIBERACIÓN
%% =========================
E7 --> K{"¿Corresponde liberación?"}:::decision

K -- "NO" --> R4["→ Retornar al origen"]:::retorno

K -- "SI" --> L{"¿Requiere documento?"}:::decision

%% SIN DOCUMENTO
L -- "NO" --> M["Ejecutar liberación<br/>operativa"]:::proceso
M --> E8["LIBERACION_EJECUTADA"]:::evento
E8 --> R5["→ Retornar al origen"]:::retorno

%% CON DOCUMENTO (P1)
L -- "SI" --> N["Invocar P1<br/>Proceso Documental"]:::documento
N --> N1["Documento generado<br/>firmado y numerado"]:::documento

N1 --> O{"¿Documento OK?"}:::decision

O -- "NO" --> E9["DOCUMENTO_LIBERACION_RECHAZADO"]:::evento
E9 --> R6["→ Retornar al origen"]:::retorno

O -- "SI" --> P["Ejecutar liberación"]:::proceso
P --> E10["LIBERACION_EJECUTADA"]:::evento
E10 --> R7["→ Retornar al origen"]:::retorno

%% =========================
%% CLASES
%% =========================
class A inicio
class B,E,H,H1,K,L,O decision
class C,D,F,G,H2,I,M,P proceso
class E1,E2,E3,E4,E5,E6,E7,E8,E9,E10 evento
class J,N,N1 documento
class R1,R2,R3,R4,R5,R6,R7 retorno