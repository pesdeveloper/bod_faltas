flowchart TD

classDef inicio fill:#1f4b99,color:#ffffff
classDef proceso fill:#e8f0fe,color:#111111
classDef decision fill:#fff4cc,color:#111111
classDef error fill:#fde7e9,color:#111111
classDef evento fill:#e7f7e7,color:#111111
classDef destino fill:#0f9d58,color:#ffffff

A["D1<br/>LABRADO<br/>ACTA"]:::inicio

A --> B{"¿Modo<br/>captura?"}:::decision

B -- OFFLINE --> C["Generar<br/>IdTecnico"]:::proceso
C --> D["Guardar<br/>local"]:::proceso
D --> E["Evento<br/>ACTA_CREADA_OFFLINE"]:::evento
E --> F["Pendiente<br/>sync"]:::proceso

B -- ONLINE --> G["Persistir<br/>servidor"]:::proceso
G --> H["Asignar Id<br/>NumeroActa"]:::proceso
H --> I["Evento<br/>ACTA_LABRADA"]:::evento
I --> Z

F --> J["Preparar<br/>sync"]:::proceso
J --> K["Evento<br/>SYNC_INICIADA"]:::evento
K --> L["Enviar<br/>servidor"]:::proceso

L --> M{"Resultado"}:::decision

M -- OK --> N["Persistir<br/>acta"]:::proceso
N --> O["Evento<br/>SYNC_EXITOSA"]:::evento
O --> P["Evento<br/>ACTA_LABRADA"]:::evento
P --> Z

M -- FALLA --> Q["Evento<br/>SYNC_FALLIDA"]:::error
Q --> R["Pendiente<br/>retry"]:::proceso

M -- CONFLICTO --> S["Evento<br/>CONFLICTO"]:::error
S --> T["Resolver<br/>conflicto"]:::proceso

R --> U["Evento<br/>SYNC_REINTENTADA"]:::evento
U --> L

T --> U

Z["Acta<br/>Operable"]:::destino

Z --> D2["→ D2"]:::destino
Z --> D3["→ D3"]:::destino
Z --> P2["→ P2"]:::destino