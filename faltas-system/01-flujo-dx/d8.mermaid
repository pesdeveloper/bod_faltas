flowchart TD

classDef inicio fill:#1f4b99,color:#ffffff
classDef proceso fill:#e8f0fe,color:#111111
classDef decision fill:#fff4cc,color:#111111
classDef evento fill:#e7f7e7,color:#111111
classDef destino fill:#0f9d58,color:#ffffff
classDef externo fill:#f3e8ff,color:#111111

A["D8<br/>CIERRE"]:::inicio

A --> B{"¿Cerrar?"}:::decision

B -- NO --> R0["Continuar flujo"]:::proceso

B -- SI --> C["Determinar<br/>TipoCierre"]:::proceso

C --> D{"Tipo?"}:::decision

D -- ARCHIVO --> E1["Evento<br/>CIERRE_ARCHIVO"]:::evento
E1 --> Z

D -- EXTERNO --> E2["Evento<br/>DERIVACION"]:::evento
E2 --> X["Sistema<br/>externo"]:::externo
X --> W["Evento<br/>RESULTADO_EXTERNO"]:::evento

W --> F{"Resultado"}:::decision

F -- CONFIRMA --> G["Cierre<br/>CUMPLIMIENTO"]:::proceso
G --> Z

F -- MODIFICA --> H["→ D5"]:::destino

F -- ANULA --> I["Cierre<br/>ANULACION"]:::proceso
I --> Z

F -- INFO --> J["→ D4"]:::destino

D -- CUMPLIMIENTO --> E3["Evento<br/>CIERRE_PAGO"]:::evento
E3 --> Z

Z["Estado<br/>CERRADA"]:::destino