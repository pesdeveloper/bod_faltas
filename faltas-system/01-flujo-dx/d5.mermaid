flowchart TD

classDef inicio fill:#1f4b99,color:#ffffff
classDef proceso fill:#e8f0fe,color:#111111
classDef decision fill:#fff4cc,color:#111111
classDef evento fill:#e7f7e7,color:#111111
classDef documento fill:#f3e8ff,color:#111111
classDef error fill:#fde7e9,color:#111111
classDef destino fill:#0f9d58,color:#ffffff

A["D5<br/>ACTO<br/>RESOLUTIVO"]:::inicio

A --> B["Definir<br/>acto"]:::proceso
B --> E1["Evento<br/>ACTO_DEFINIDO"]:::evento

E1 --> C["Generar<br/>documento"]:::documento
C --> E2["Evento<br/>DOCUMENTO_GENERADO"]:::evento

E2 --> D["Invocar<br/>P1"]:::documento

D --> F{"Resultado"}:::decision

F -- FIRMADO --> E3["Evento<br/>ACTO_FORMALIZADO"]:::evento
E3 --> D6["→ D6"]:::destino

F -- PENDIENTE --> E4["Evento<br/>FIRMA_SOLICITADA"]:::evento
E4 --> A

F -- ERROR --> E5["Evento<br/>ERROR_FIRMA"]:::error
E5 --> A